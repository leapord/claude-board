{
  "name": "claude-board",
  "version": "0.3.1",
  "description": "Claude Board — 跨平台 AI 使用追踪桌面工具",
  "main": "src/main/main.js",
  "author": "qiyuyang",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:all": "electron-builder --mac --win"
  },
  "devDependencies": {
    "canvas": "^3.2.3",
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.qiyuyang.claudeboard",
    "productName": "ClaudeBoard",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "icon": "build/icon",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "artifactName": "ClaudeBoard-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "artifactName": "ClaudeBoard-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "artifactName": "ClaudeBoard-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Claude Board"
    },
    "portable": {
      "artifactName": "ClaudeBoard-Portable-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "artifactName": "ClaudeBoard-${version}-${arch}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "leapord",
      "repo": "claude-board",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.8.9"
  }
}
